# AMI-DATAOPS Environment Variables
# Copy to .env and fill in all values before running `make deploy`

# --- PostgreSQL ---
POSTGRES_DB=postgres
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_PORT=5432

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=your_mongo_user
MONGO_INITDB_ROOT_PASSWORD=your_secure_mongo_password
MONGO_PORT=27017

# --- Dgraph ---
DGRAPH_HTTP_PORT=8081
DGRAPH_GRPC_PORT=9081

# --- Prometheus ---
PROMETHEUS_PORT=9091
PROMETHEUS_RETENTION=30d

# --- Redis ---
REDIS_PORT=6379

# --- OpenBao (Secrets) ---
OPENBAO_DEV_ROOT_TOKEN_ID=your_secure_openbao_token
OPENBAO_PORT=8200
OPENBAO_LOG_LEVEL=info

# --- Keycloak (Identity) ---
KEYCLOAK_ADMIN=your_keycloak_admin_user
KEYCLOAK_ADMIN_PASSWORD=your_secure_keycloak_password
KEYCLOAK_DB=keycloak
KEYCLOAK_PORT=8082
KEYCLOAK_MGMT_PORT=9082
KEYCLOAK_REALM=ami
KEYCLOAK_CLIENT_ID=ami-portal

# --- Vaultwarden ---
VAULTWARDEN_DOMAIN=http://127.0.0.1:8083
VAULTWARDEN_PORT=8083
VAULTWARDEN_SIGNUPS_ALLOWED=false
VAULTWARDEN_INVITATIONS_ALLOWED=false
VAULTWARDEN_WEBSOCKET_ENABLED=true

# --- SearXNG ---
SEARXNG_SECRET=your_secure_searxng_secret
SEARXNG_BASE_URL=http://127.0.0.1:8888
SEARXNG_PORT=8888
SEARXNG_REDIS_URL=redis://searxng-redis:6380/0
SEARXNG_LIMITER=true
SEARXNG_REDIS_PORT=6380

# --- OpenVPN (optional, vpn profile) ---
OPENVPN_PUID=1000
OPENVPN_PGID=1000
OPENVPN_TZ=UTC
OPENVPN_INTERFACE=eth0

# --- Portal Integration ---
# Portal URL for Keycloak OIDC client redirect URIs.
# Also read by AMI-PORTAL playbooks via -include to avoid config duplication.
NEXTAUTH_URL=https://your-portal-host:3000
